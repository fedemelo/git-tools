#!/usr/bin/env bash
set -euo pipefail

force=0
args=()
for arg in "$@"; do
  if [ "$arg" = "--force" ]; then
    force=1
  else
    args+=("$arg")
  fi
done
title="${args[0]:-}"

branch="$(git symbolic-ref --short HEAD)" || {
  echo "git-land: not on a branch (detached HEAD)" >&2
  exit 1
}

upstream="$(git rev-parse --abbrev-ref --symbolic-full-name "@{u}" 2>/dev/null)" || {
  echo "git-land: '$branch' has no upstream tracking branch" >&2
  exit 1
}

remote="${upstream%%/*}"

remote_url="$(git remote get-url "$remote")"
repo_owner="$(gh repo view "$remote_url" --json owner -q .owner.login)"
viewer_login="$(gh api user -q .login)"

if [ "$repo_owner" != "$viewer_login" ] && [ "$force" -ne 1 ]; then
  echo "git-land: '$remote' ($repo_owner/...) isn't owned by you ($viewer_login) — refusing to auto-merge without review on someone else's repo." >&2
  echo "git-land: pass --force if you're sure this is still solo/unreviewed work." >&2
  exit 1
fi

git fetch "$remote" "$branch"

read -r behind ahead < <(git rev-list --left-right --count "@{u}...HEAD")

if [ "$behind" -gt 0 ]; then
  echo "git-land: '$branch' is $behind commit(s) behind '$upstream' — pull/rebase first" >&2
  exit 1
fi

if [ "$ahead" -eq 0 ]; then
  echo "git-land: nothing to land, '$branch' is up to date with '$upstream'" >&2
  exit 1
fi

old_head="$(git rev-parse HEAD)"

if [ -z "$title" ]; then
  title="$(git log -1 --format=%s)"
fi

body="$(git log --format='- %s' "@{u}..HEAD")"

tmp="tmp/${branch}-$(git rev-parse --short HEAD)"

echo "git-land: pushing $ahead commit(s) to $remote/$tmp"
git push "$remote" "HEAD:refs/heads/$tmp"

cleanup() {
  if [ "${merged:-0}" -ne 1 ]; then
    echo "git-land: leaving $remote/$tmp pushed for manual recovery" >&2
  fi
}
merged=0
trap cleanup EXIT

pr_url="$(gh pr create --base "$branch" --head "$tmp" --title "$title" --body "$body" --assignee @me)"
echo "git-land: opened $pr_url"

gh pr comment "$pr_url" --body "PR automatically created and merged without review for recordkeeping."

# Push the exact local (already-signed) commits straight onto the base branch.
# behind==0 was already confirmed, so this is a plain fast-forward — no server-side
# rebase involved, unlike `gh pr merge --rebase`, which would recreate the commits via
# GitHub's API and strip GPG signatures / rewrite the committer to the GitHub account email.
if git push "$remote" "HEAD:refs/heads/$branch"; then
  merged=1
  echo "git-land: pushed directly to $remote/$branch (signatures preserved); PR will auto-close as merged"
  git push "$remote" --delete "$tmp" || echo "git-land: could not delete $remote/$tmp, leaving it" >&2
else
  echo "git-land: direct push rejected (branch protection?) — falling back to API rebase-merge" >&2
  echo "git-land: warning — this path recreates commits via GitHub's API, losing GPG signatures and rewriting the committer email" >&2

  if gh pr merge "$pr_url" --rebase --delete-branch; then
    merged=1
    echo "git-land: merged immediately"

    git fetch "$remote" "$branch"

    if git diff --quiet "$old_head" "$remote/$branch"; then
      git update-ref "refs/heads/$branch" "$remote/$branch"
      echo "git-land: local '$branch' synced to $remote/$branch"
    else
      echo "git-land: warning — $remote/$branch diverged from expected content (concurrent push?)." >&2
      echo "git-land: not touching local '$branch'. Run 'git pull --rebase' to reconcile." >&2
    fi
  else
    echo "git-land: immediate merge blocked (checks/review required), scheduling auto-merge"
    if gh pr merge "$pr_url" --rebase --auto --delete-branch; then
      merged=1
      echo "git-land: auto-merge enabled. It will land once checks pass — local '$branch' not yet synced."
      echo "git-land: run 'git pull --rebase' once it's merged."
    else
      echo "git-land: could not enable auto-merge either — PR left open at $pr_url" >&2
      exit 1
    fi
  fi
fi
